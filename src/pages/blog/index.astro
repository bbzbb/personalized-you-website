---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'why-we-built-personalized-bedtime-stories',
    title: "We Made a Bedtime Story for One Child. Then We Couldn't Stop.",
    date: 'April 2026',
    excerpt: "The story of how Personalized You started — and why we believe every child deserves to be the hero of their own adventure.",
  },
];
---
<Layout title="Blog" description="Tips, insights, and stories from Personalized You.">
  <div style="max-width:700px;margin:0 auto;padding:4rem 2rem;">
    <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:0.75rem;text-align:center;">Blog</h1>
    <p style="color:#7a7068;text-align:center;margin-bottom:3rem;">Tips, insights, and stories from Personalized You.</p>

    <div style="display:flex;flex-direction:column;gap:1.5rem;">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} style="display:block;background:#eeebe6;border:1px solid #d9d3cc;border-radius:16px;padding:2rem;text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#8aab8e'" onmouseout="this.style.borderColor='#d9d3cc'">
          <p style="color:#7a7068;font-size:0.875rem;margin-bottom:0.5rem;">{post.date} · 5 min read</p>
          <h2 style="color:#2c2c2c;font-size:1.3rem;margin-bottom:0.75rem;">{post.title}</h2>
          <p style="color:#7a7068;line-height:1.6;">{post.excerpt}</p>
          <p style="color:#8aab8e;margin-top:1rem;font-weight:600;">Read more →</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
