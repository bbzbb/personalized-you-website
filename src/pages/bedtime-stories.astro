---
import Layout from '../layouts/Layout.astro';

const shopifyUrl = 'https://shop.personalized-you.com/products/personalized-bedtime-story-read-aloud-audio';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "Personalized Bedtime Story — Read Aloud Audio",
      "description": "A fully custom bedtime story written around your child — their name, personality, and favorite things. Delivered as a read-aloud audio file within 24 hours.",
      "url": "https://www.personalized-you.com/bedtime-stories/",
      "image": "https://www.personalized-you.com/og-bedtime.jpg",
      "brand": {
        "@type": "Brand",
        "name": "Personalized You"
      },
      "offers": [
        {
          "@type": "Offer",
          "name": "Standard (5–6 min read)",
          "price": "19.99",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": shopifyUrl
        },
        {
          "@type": "Offer",
          "name": "Extended (8–10 min read)",
          "price": "29.99",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": shopifyUrl
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "3"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.personalized-you.com/" },
        { "@type": "ListItem", "position": 2, "name": "Bedtime Stories", "item": "https://www.personalized-you.com/bedtime-stories/" }
      ]
    }
  ]
};
---
<Layout
  title="Personalized Bedtime Stories for Kids"
  description="Custom bedtime stories starring your child. We write an original read-aloud audio story around their name, age, and personality — delivered in 24 hours. From $19.99."
  canonical="https://www.personalized-you.com/bedtime-stories/"
  ogType="product"
  schema={schema}
>
  <div style="max-width:800px;margin:0 auto;padding:4rem 2rem;">

    <!-- Hero -->
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:3rem;margin-bottom:1rem;">📖</div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.75rem);font-weight:700;line-height:1.2;margin-bottom:1rem;color:#b07d50;">
        A bedtime story your child will ask for every night — starring them
      </h1>
      <p style="font-size:1.15rem;color:#7a6a5a;max-width:540px;margin:0 auto 2rem;">
        Original read-aloud audio stories crafted around your child's name, personality, and world. Delivered in 24 hours.
      </p>
      <a href={shopifyUrl} target="_blank" rel="noopener noreferrer"
        style="display:inline-block;background:#7a9e7e;color:#ffffff;font-weight:700;padding:0.9rem 2.5rem;border-radius:2rem;font-size:1.1rem;box-shadow:0 4px 14px rgba(122,158,126,0.35);transition:background 0.2s;"
        onmouseover="this.style.background='#5f8463'" onmouseout="this.style.background='#7a9e7e'">
        Get Your Child's Story — From $19.99
      </a>
      <p style="color:#7a6a5a;margin-top:0.75rem;font-size:0.875rem;">Secure checkout · Delivered in 24 hours · Full refund guarantee</p>
    </div>

    <!-- How It Works -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#b07d50;font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;text-align:center;">How It Works</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
        {[
          { n: '1', icon: '✏️', title: 'Tell us about your child', body: "Share their name, age, favorite things, and the kind of adventure they'd love." },
          { n: '2', icon: '✨', title: 'We craft a story just for them', body: 'Every detail — the hero, the quest, the magic — is built around your child.' },
          { n: '3', icon: '🌙', title: 'Your child falls asleep to their own adventure', body: 'Receive a read-aloud audio story within 24 hours, ready for tonight.' },
        ].map(s => (
          <div style="background:#e8d9c5;border:2px solid #d9cfc4;border-radius:14px;padding:1.5rem;text-align:center;box-shadow:0 2px 8px rgba(44,44,44,0.06);">
            <div style="font-size:2rem;margin-bottom:0.5rem;">{s.icon}</div>
            <div style="color:#7a9e7e;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;margin-bottom:0.5rem;">STEP {s.n}</div>
            <h3 style="font-size:1rem;font-weight:700;color:#b07d50;margin-bottom:0.5rem;">{s.title}</h3>
            <p style="color:#7a6a5a;font-size:0.9rem;line-height:1.6;">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Story sample -->
    <section style="background:#e8d9c5;border-radius:20px;padding:2.25rem;margin-bottom:3rem;">
      <h2 style="color:#b07d50;font-size:1.2rem;font-weight:700;margin-bottom:0.5rem;text-align:center;">Read a sample story</h2>
      <p style="color:#7a9e7e;font-size:0.8rem;text-align:center;margin-bottom:1.5rem;letter-spacing:0.05em;font-weight:600;">EMMA AND THE STORM DRAGON — EXCERPT</p>
      <div style="border-left:4px solid #7a9e7e;padding-left:1.25rem;">
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;">
          Emma had never seen a dragon quite like this one.
        </p>
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;margin-top:0.75rem;">
          It wasn't the fearsome, fire-breathing kind from the books at school. This dragon was small — barely bigger than Emma's backpack — with scales the color of summer storms and eyes like warm amber honey. It sat perched on the windowsill, watching her with quiet curiosity.
        </p>
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;margin-top:0.75rem;">
          "You're real," Emma whispered, hardly believing it.
        </p>
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;margin-top:0.75rem;">
          The dragon tilted its tiny head and made a sound somewhere between a purr and a rumble. Then it stretched its wings — just a little — as if to say: <em>of course I am.</em>
        </p>
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;margin-top:0.75rem;">
          Emma reached out her hand. The dragon stepped forward, its claws clicking softly on the sill, and pressed its warm nose into her palm.
        </p>
        <p style="color:#3a2e28;line-height:1.8;font-size:0.975rem;margin-top:0.75rem;">
          Outside, the stars were just beginning to appear. And Emma — the girl who had always believed in dragons — had just been believed in back.
        </p>
      </div>
      <p style="color:#7a9e7e;font-size:0.85rem;text-align:center;margin-top:1.25rem;font-weight:600;">Your child's story is written just for them — their name, their world, their adventure.</p>
    </section>

    <!-- Pricing -->
    <section style="background:#e8d9c5;border:2px solid #d9cfc4;border-radius:20px;padding:2rem;text-align:center;margin-bottom:3rem;box-shadow:0 2px 8px rgba(44,44,44,0.06);">
      <h2 style="color:#b07d50;font-weight:700;margin-bottom:1.5rem;">Choose Your Story</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;text-align:left;">
        {[
          { label: 'Standard', duration: '5–6 min read', price: '$19.99', desc: 'A complete original story with your child as the hero. Perfect for ages 3–8.' },
          { label: 'Extended', duration: '8–10 min read', price: '$29.99', desc: 'A longer adventure with richer world-building. Great for older kids or longer bedtimes.' },
        ].map(p => (
          <div style="background:#fdf8f0;border:2px solid #d9cfc4;border-radius:14px;padding:1.5rem;">
            <div style="color:#7a9e7e;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;margin-bottom:0.5rem;">{p.duration}</div>
            <div style="font-size:1.75rem;font-weight:700;color:#b07d50;margin-bottom:0.5rem;">{p.price}</div>
            <div style="font-weight:700;color:#3a2e28;margin-bottom:0.5rem;">{p.label}</div>
            <p style="color:#7a6a5a;font-size:0.875rem;line-height:1.6;">{p.desc}</p>
          </div>
        ))}
      </div>
      <p style="color:#7a6a5a;font-size:0.875rem;margin-top:1.25rem;">All stories delivered as read-aloud audio within 24 hours</p>
    </section>

    <!-- Guarantee -->
    <section style="background:#e8d9c5;border:2px solid #7a9e7e;border-radius:20px;padding:2rem;text-align:center;margin-bottom:3rem;">
      <p style="color:#7a9e7e;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;margin-bottom:0.75rem;">OUR GUARANTEE</p>
      <h2 style="font-size:1.4rem;font-weight:700;color:#b07d50;margin-bottom:0.75rem;">The Bedtime Promise</h2>
      <p style="color:#7a6a5a;line-height:1.7;max-width:500px;margin:0 auto;">
        If your child doesn't ask for it again, full refund. No questions, no hoops — just message us.
      </p>
    </section>

    <!-- Testimonials -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#b07d50;font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;text-align:center;">What parents are saying</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;">
        {[
          { name: 'Sarah M.', location: 'Austin, TX', quote: "My daughter made me read it three nights in a row. She keeps asking when her dragon is coming back. Worth every penny." },
          { name: 'James T.', location: 'Portland, OR', quote: "I was skeptical but this genuinely blew me away. The story had her personality down perfectly. She thought we had a secret author friend." },
          { name: 'Priya K.', location: 'Chicago, IL', quote: "We ordered it as a birthday surprise. He cried — the good kind. He's been carrying the printed copy around the house all week." },
        ].map(t => (
          <div style="background:#e8d9c5;border:2px solid #d9cfc4;border-radius:14px;padding:1.5rem;box-shadow:0 2px 8px rgba(44,44,44,0.06);">
            <div style="color:#b07d50;font-size:1rem;margin-bottom:0.75rem;">★★★★★</div>
            <p style="color:#3a2e28;line-height:1.7;font-size:0.95rem;margin-bottom:1rem;">"{t.quote}"</p>
            <p style="color:#3a2e28;font-weight:700;font-size:0.875rem;">{t.name}</p>
            <p style="color:#7a6a5a;font-size:0.8rem;">{t.location}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#b07d50;font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;text-align:center;">Frequently Asked Questions</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {[
          { q: 'How does my child become the main character?', a: "When you order, you'll fill out a short form with your child's name, age, and a few things they love. We build the whole story around those details." },
          { q: 'What format is the story delivered in?', a: 'You receive a read-aloud audio file — narrated, produced, and ready to play at bedtime. No reading required on your end.' },
          { q: 'How long does delivery take?', a: 'Stories are delivered within 24 hours of your order. Most arrive faster.' },
          { q: 'What age is this best for?', a: 'Ages 3–10 are the sweet spot, but we tailor every story to the child. Just let us know their age when you order.' },
          { q: 'What if I\'m not happy with the story?', a: 'Full refund, no questions. That\'s The Bedtime Promise.' },
        ].map(item => (
          <div style="background:#e8d9c5;border:2px solid #d9cfc4;border-radius:14px;padding:1.5rem;box-shadow:0 2px 8px rgba(44,44,44,0.06);">
            <h3 style="color:#b07d50;font-weight:700;font-size:1rem;margin-bottom:0.5rem;">{item.q}</h3>
            <p style="color:#7a6a5a;font-size:0.9rem;line-height:1.6;">{item.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <div style="text-align:center;">
      <h2 style="color:#b07d50;font-size:1.5rem;font-weight:700;margin-bottom:0.75rem;">Ready to make bedtime magical?</h2>
      <p style="color:#7a6a5a;margin-bottom:1.5rem;">One story. One child. All theirs.</p>
      <a href={shopifyUrl} target="_blank" rel="noopener noreferrer"
        style="display:inline-block;background:#7a9e7e;color:#ffffff;font-weight:700;padding:1rem 2.75rem;border-radius:2rem;font-size:1.1rem;box-shadow:0 4px 14px rgba(122,158,126,0.35);transition:background 0.2s;"
        onmouseover="this.style.background='#5f8463'" onmouseout="this.style.background='#7a9e7e'">
        Order Now — From $19.99
      </a>
      <p style="color:#7a6a5a;margin-top:1rem;font-size:0.875rem;">Secure checkout · Delivered in 24 hours</p>
    </div>
  </div>
</Layout>
