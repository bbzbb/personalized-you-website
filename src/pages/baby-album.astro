---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Personalized Baby Photo Album",
  "description": "A hardcover personalized baby photo album with your baby's name and birth date on the cover. 24 designed interior pages covering the first year. Ships from the US.",
  "brand": {
    "@type": "Brand",
    "name": "Personalized You"
  },
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "42",
    "highPrice": "58",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "5"
  }
};
---
<Layout
  title="Personalized Baby Photo Album — Hardcover Keepsake Book"
  description="A hardcover personalized baby photo album with your baby name and birth date on the cover. 24 designed interior pages covering the first year. Ships from the US."
  schema={schema}
>

  <!-- Hero -->
  <section class="hero">
    <h1>The first year goes fast.<br><span>This is how you hold onto it.</span></h1>
    <p>Personalized hardcover photo albums for babies and toddlers ages 0 to 6 — handcrafted with love, built to last a lifetime.</p>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" class="btn-primary"
      onmouseover="this.style.background='#4a6347'" onmouseout="this.style.background='#5C7A58'">Shop on Etsy</a>
  </section>

  <!-- Carousel -->
  <section class="carousel-section">
    <div class="carousel-track">
      <div class="carousel-slide"><img src="/images/baby-album/mock2.jpg" alt="Personalized baby photo album mockup" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/mock4.png" alt="Personalized baby photo album" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/supporting4.png" alt="Personalized baby photo album lifestyle" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-20.png" alt="Album interior page 20" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-01.png" alt="Album interior page 1" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-05.png" alt="Album interior page 5" loading="lazy" /></div>
    </div>
  </section>

  <!-- Peek Inside -->
  <section class="peek-section">
    <div class="peek-inner">
      <div class="peek-caption">
        <h2>Peek Inside</h2>
        <p>Every page tells a story — yours.</p>
      </div>
      <div class="peek-grid">
        <img src="/images/baby-album/mock2.jpg" alt="Personalized baby photo album mockup" loading="lazy" />
        <img src="/images/baby-album/mock4.png" alt="Personalized baby photo album" loading="lazy" />
        <img src="/images/baby-album/supporting4.png" alt="Personalized baby photo album lifestyle" loading="lazy" />
        <img src="/images/baby-album/page-20.png" alt="Album interior page 20" loading="lazy" />
        <img src="/images/baby-album/page-01.png" alt="Album interior page 1" loading="lazy" />
        <img src="/images/baby-album/page-05.png" alt="Album interior page 5" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-section">
    <h2>Ready to preserve every milestone?</h2>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" class="btn-primary"
      onmouseover="this.style.background='#4a6347'" onmouseout="this.style.background='#5C7A58'">Shop on Etsy</a>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 5rem 2rem 3.5rem;
      max-width: 820px;
      margin: 0 auto;
      background: var(--cream);
      border-radius: 0 0 24px 24px;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      color: var(--latte);
    }
    .hero h1 span { color: #5C7A58; }
    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto 2.5rem;
    }
    .btn-primary {
      display: inline-block;
      background: #5C7A58;
      color: #fff;
      font-weight: 700;
      padding: 0.9rem 2.25rem;
      border-radius: 2rem;
      font-size: 1rem;
      box-shadow: 0 4px 14px rgba(92,122,88,0.3);
      text-decoration: none;
      transition: background 0.2s;
    }
    .carousel-section {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }
    .carousel-track {
      display: flex;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      border-radius: 16px;
    }
    .carousel-track::-webkit-scrollbar { display: none; }
    .carousel-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }
    .carousel-slide img {
      width: 100%;
      height: auto;
      border-radius: 16px;
      display: block;
    }
    .peek-section {
      background: var(--surface-2);
      padding: 4rem 2rem;
    }
    .peek-inner {
      max-width: 960px;
      margin: 0 auto;
    }
    .peek-caption {
      background: var(--surface-2);
      border-radius: 12px;
      padding: 1.5rem 2rem;
      text-align: center;
      margin-bottom: 2rem;
    }
    .peek-caption h2 {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--latte);
      margin-bottom: 0.5rem;
    }
    .peek-caption p { color: var(--text); }
    .peek-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .peek-grid img {
      width: 100%;
      height: auto;
      border-radius: 10px;
      display: block;
      box-shadow: 0 2px 8px rgba(44,44,44,0.08);
    }
    .cta-section {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--beige);
    }
    .cta-section h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--latte);
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #5C7A58;
      display: block;
    }
    @media (max-width: 768px) {
      .peek-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

</Layout>
