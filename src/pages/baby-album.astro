---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Personalized Baby Photo Albums" description="Hardcover personalized baby photo albums for the first year. A keepsake they'll treasure forever. Shop on Etsy.">

  <!-- Hero -->
  <section class="hero">
    <h1>The first year goes fast.<br><span>This is how you hold onto it.</span></h1>
    <p>Personalized hardcover baby photo albums — handcrafted with love, built to last a lifetime.</p>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" class="btn-primary"
      onmouseover="this.style.background='#6d8e71'" onmouseout="this.style.background='#8aab8e'">Shop on Etsy</a>
  </section>

  <!-- Carousel -->
  <section class="carousel-section">
    <div class="carousel-track">
      <div class="carousel-slide"><img src="/images/baby-album/supporting4.png" alt="Personalized baby photo album lifestyle" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/mock2.jpg" alt="Personalized baby photo album mockup" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-01.png" alt="Album interior page 1" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-05.png" alt="Album interior page 5" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/page-20.png" alt="Album interior page 20" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/supporting2.png" alt="Personalized baby photo album lifestyle" loading="lazy" /></div>
    </div>
  </section>

  <!-- Peek Inside -->
  <section class="peek-section">
    <div class="peek-inner">
      <div class="peek-caption">
        <h2>Peek Inside</h2>
        <p>Every page tells a story — yours.</p>
      </div>
      <div class="peek-grid">
        <img src="/images/baby-album/page-01.png" alt="Album interior page 1" loading="lazy" />
        <img src="/images/baby-album/page-02.png" alt="Album interior page 2" loading="lazy" />
        <img src="/images/baby-album/page-03.png" alt="Album interior page 3" loading="lazy" />
        <img src="/images/baby-album/page-04.png" alt="Album interior page 4" loading="lazy" />
        <img src="/images/baby-album/page-05.png" alt="Album interior page 5" loading="lazy" />
        <img src="/images/baby-album/page-06.png" alt="Album interior page 6" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-section">
    <h2>Ready to preserve every milestone?</h2>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" class="btn-primary"
      onmouseover="this.style.background='#6d8e71'" onmouseout="this.style.background='#8aab8e'">Shop on Etsy</a>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 5rem 2rem 3.5rem;
      max-width: 820px;
      margin: 0 auto;
      background: linear-gradient(160deg, var(--cream) 0%, var(--bg) 100%);
      border-radius: 0 0 24px 24px;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      color: var(--text);
    }
    .hero h1 span { color: var(--primary); }
    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto 2.5rem;
    }
    .btn-primary {
      display: inline-block;
      background: var(--primary);
      color: #fff;
      font-weight: 700;
      padding: 0.9rem 2.25rem;
      border-radius: 10px;
      font-size: 1rem;
      box-shadow: 0 4px 14px rgba(138,171,142,0.35);
      text-decoration: none;
      transition: background 0.2s;
    }
    .carousel-section {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }
    .carousel-track {
      display: flex;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      border-radius: 16px;
    }
    .carousel-track::-webkit-scrollbar { display: none; }
    .carousel-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }
    .carousel-slide img {
      width: 100%;
      height: auto;
      border-radius: 16px;
      display: block;
    }
    .peek-section {
      background: var(--surface);
      padding: 4rem 2rem;
    }
    .peek-inner {
      max-width: 960px;
      margin: 0 auto;
    }
    .peek-caption {
      background: var(--lavender);
      border-radius: 12px;
      padding: 1.5rem 2rem;
      text-align: center;
      margin-bottom: 2rem;
    }
    .peek-caption h2 {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    .peek-caption p { color: var(--text); }
    .peek-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .peek-grid img {
      width: 100%;
      height: auto;
      border-radius: 10px;
      display: block;
      box-shadow: 0 2px 8px rgba(44,44,44,0.08);
    }
    .cta-section {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--cream);
    }
    .cta-section h2 {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--gold);
      display: inline-block;
    }
    @media (max-width: 768px) {
      .peek-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

</Layout>
