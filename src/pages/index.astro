---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Personalized Keepsakes for Little Ones" description="Handcrafted personalized digital products — baby photo albums and bedtime stories made just for your family.">

  <!-- Hero -->
  <section class="hero">
    <h1>Made just for your family.<br><span>Keepsakes they'll treasure forever.</span></h1>
    <p>Personalized hardcover baby albums and custom bedtime stories — crafted with love.</p>
  </section>

  <!-- Product Cards -->
  <section class="products">
    <div class="card">
      <div class="badge">Baby Album</div>
      <h2>Personalized Baby Photo Album</h2>
      <p>Preserve every milestone from the first year in a beautiful hardcover keepsake album, personalized with your baby's name.</p>
      <a href="/baby-album" class="btn-primary">See the Album →</a>
    </div>
    <div class="card">
      <div class="badge badge-lilac">Bedtime Story</div>
      <h2>Custom Bedtime Story Book</h2>
      <p>A magical storybook starring your child by name — the perfect bedtime ritual and a gift they'll ask for every night.</p>
      <a href="/bedtime-stories" class="btn-secondary">See the Story →</a>
    </div>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 5rem 2rem 3.5rem;
      max-width: 820px;
      margin: 0 auto;
      background: var(--cream);
      border-radius: 0 0 24px 24px;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      color: var(--latte);
    }
    .hero h1 span { color: #5C7A58; }
    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto;
    }
    .products {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      max-width: 960px;
      margin: 4rem auto;
      padding: 0 2rem;
    }
    .card {
      background: var(--beige);
      border: 1px solid var(--border);
      border-top: 3px solid #5C7A58;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .badge {
      display: inline-block;
      background: #A85C5C;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      width: fit-content;
    }
    .badge-lilac {
      background: #6B4A8A;
      color: #fff;
    }
    .card h2 {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--latte);
    }
    .card p {
      color: var(--muted);
      line-height: 1.6;
      flex: 1;
    }
    .btn-primary {
      display: inline-block;
      background: #A85C5C;
      color: #fff;
      font-weight: 700;
      padding: 0.8rem 1.75rem;
      border-radius: 2rem;
      font-size: 1rem;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
      width: fit-content;
    }
    .btn-primary:hover { background: #8f4a4a; text-decoration: none; }
    .btn-secondary {
      display: inline-block;
      background: #6B4A8A;
      color: #fff;
      font-weight: 700;
      padding: 0.8rem 1.75rem;
      border-radius: 2rem;
      font-size: 1rem;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
      width: fit-content;
    }
    .btn-secondary:hover { background: #4e3468; text-decoration: none; }
    @media (max-width: 640px) {
      .products { grid-template-columns: 1fr; }
    }
  </style>

</Layout>
