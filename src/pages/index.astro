---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home" description="Personalized handcrafted digital gifts — bedtime stories and guided meditation made just for you.">

  <!-- Hero -->
  <section style="text-align:center;padding:5rem 2rem 3.5rem;max-width:820px;margin:0 auto;">
    <div style="display:inline-block;background:#f0eaff;color:#7c5cbf;font-size:0.8rem;font-weight:700;letter-spacing:0.08em;padding:0.35rem 1rem;border-radius:99px;margin-bottom:1.25rem;">✨ Crafted with love · Made for one person · Yours</div>
    <h1 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:800;line-height:1.15;margin-bottom:1rem;color:#1a1a2e;">
      The gift they'll never forget —<br><span style="color:#7c5cbf">because it's theirs forever</span>
    </h1>
    <p style="font-size:1.2rem;color:#6b6b8a;max-width:560px;margin:0 auto 2.5rem;">
      Stories and meditations crafted with love for one person — yours.
    </p>
    <a href="/bedtime-stories" style="display:inline-block;background:#ff6b35;color:#ffffff;font-weight:700;padding:0.9rem 2.25rem;border-radius:10px;font-size:1rem;margin-right:1rem;margin-bottom:1rem;box-shadow:0 4px 14px rgba(255,107,53,0.35);transition:background 0.2s;" onmouseover="this.style.background='#e85a25'" onmouseout="this.style.background='#ff6b35'">Explore Stories</a>
    <a href="/meditation" style="display:inline-block;border:2px solid #2d1b69;color:#2d1b69;font-weight:700;padding:0.9rem 2.25rem;border-radius:10px;font-size:1rem;margin-bottom:1rem;transition:background 0.2s;" onmouseover="this.style.background='rgba(45,27,105,0.07)'" onmouseout="this.style.background='transparent'">Explore Meditation</a>
  </section>

  <!-- Use-case selector -->
  <section style="max-width:900px;margin:0 auto;padding:0 2rem 4rem;">
    <h2 style="text-align:center;font-size:1.35rem;font-weight:700;margin-bottom:1.75rem;color:#1a1a2e;">What are you looking for?</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
      <a href="/bedtime-stories" style="display:block;background:#ffffff;border:2px solid #e8dff5;border-radius:14px;padding:1.5rem;text-align:center;text-decoration:none;box-shadow:0 2px 8px rgba(45,27,105,0.06);transition:border-color 0.2s,box-shadow 0.2s;" onmouseover="this.style.borderColor='#7c5cbf';this.style.boxShadow='0 4px 16px rgba(124,92,191,0.15)'" onmouseout="this.style.borderColor='#e8dff5';this.style.boxShadow='0 2px 8px rgba(45,27,105,0.06)'">
        <div style="font-size:2rem;margin-bottom:0.75rem;">📖</div>
        <p style="color:#1a1a2e;font-weight:700;margin-bottom:0.25rem;">A bedtime story for my child</p>
        <p style="color:#6b6b8a;font-size:0.85rem;">Starring them by name</p>
      </a>
      <a href="/meditation" style="display:block;background:#ffffff;border:2px solid #e8dff5;border-radius:14px;padding:1.5rem;text-align:center;text-decoration:none;box-shadow:0 2px 8px rgba(45,27,105,0.06);transition:border-color 0.2s,box-shadow 0.2s;" onmouseover="this.style.borderColor='#7c5cbf';this.style.boxShadow='0 4px 16px rgba(124,92,191,0.15)'" onmouseout="this.style.borderColor='#e8dff5';this.style.boxShadow='0 2px 8px rgba(45,27,105,0.06)'">
        <div style="font-size:2rem;margin-bottom:0.75rem;">🧘</div>
        <p style="color:#1a1a2e;font-weight:700;margin-bottom:0.25rem;">A meditation just for me</p>
        <p style="color:#6b6b8a;font-size:0.85rem;">Built around your life, not a template</p>
      </a>
      <a href="/bedtime-stories" style="display:block;background:#ffffff;border:2px solid #e8dff5;border-radius:14px;padding:1.5rem;text-align:center;text-decoration:none;box-shadow:0 2px 8px rgba(45,27,105,0.06);transition:border-color 0.2s,box-shadow 0.2s;" onmouseover="this.style.borderColor='#7c5cbf';this.style.boxShadow='0 4px 16px rgba(124,92,191,0.15)'" onmouseout="this.style.borderColor='#e8dff5';this.style.boxShadow='0 2px 8px rgba(45,27,105,0.06)'">
        <div style="font-size:2rem;margin-bottom:0.75rem;">🎁</div>
        <p style="color:#1a1a2e;font-weight:700;margin-bottom:0.25rem;">A thoughtful gift</p>
        <p style="color:#6b6b8a;font-size:0.85rem;">Something they'll never already have</p>
      </a>
    </div>
  </section>

  <!-- Product cards -->
  <section style="background:#f0eaff;padding:4rem 2rem;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;max-width:900px;margin:0 auto;">
      <a href="/bedtime-stories" style="display:block;background:#ffffff;border-radius:20px;padding:2.25rem;transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;box-shadow:0 4px 16px rgba(45,27,105,0.09);" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 28px rgba(45,27,105,0.14)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(45,27,105,0.09)'">
        <div style="font-size:2.75rem;margin-bottom:1rem;">📖</div>
        <h2 style="color:#2d1b69;font-size:1.4rem;margin-bottom:0.35rem;font-weight:800;">Personalized Bedtime Stories</h2>
        <p style="color:#ff6b35;font-size:1.75rem;font-weight:800;margin-bottom:0.5rem;">From $19.99</p>
        <p style="color:#6b6b8a;line-height:1.6;font-size:0.95rem;">Your child is the hero. Their name, their interests, their adventure — delivered in 24 hours.</p>
        <p style="color:#ff6b35;margin-top:1.25rem;font-weight:700;font-size:0.95rem;">Order on Shopify →</p>
      </a>
      <a href="/meditation" style="display:block;background:#ffffff;border-radius:20px;padding:2.25rem;transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;box-shadow:0 4px 16px rgba(45,27,105,0.09);" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 28px rgba(45,27,105,0.14)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(45,27,105,0.09)'">
        <div style="font-size:2.75rem;margin-bottom:1rem;">🧘</div>
        <h2 style="color:#2d1b69;font-size:1.4rem;margin-bottom:0.35rem;font-weight:800;">Personalized Guided Meditation</h2>
        <p style="color:#ff6b35;font-size:1.75rem;font-weight:800;margin-bottom:0.5rem;">From $9.99</p>
        <p style="color:#6b6b8a;line-height:1.6;font-size:0.95rem;">Custom audio built around your goals and what's weighing on you — not a generic playlist.</p>
        <p style="color:#ff6b35;margin-top:1.25rem;font-weight:700;font-size:0.95rem;">Get it now →</p>
      </a>
    </div>
  </section>

</Layout>
