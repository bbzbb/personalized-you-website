---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Personalized Baby Photo Albums" description="Hardcover personalized baby photo albums for the first year. A keepsake they'll treasure forever. Shop on Etsy.">

  <!-- Hero -->
  <section style="text-align:center;padding:5rem 2rem 3.5rem;max-width:820px;margin:0 auto;">
    <h1 style="font-size:clamp(2rem,5vw,3.25rem);font-weight:800;line-height:1.2;margin-bottom:1.25rem;color:#1a1a2e;">
      The first year goes fast.<br><span style="color:#7c5cbf">This is how you hold onto it.</span>
    </h1>
    <p style="font-size:1.15rem;color:#6b6b8a;max-width:540px;margin:0 auto 2.5rem;">
      Personalized hardcover baby photo albums — handcrafted with love, built to last a lifetime.
    </p>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" style="display:inline-block;background:#ff6b35;color:#ffffff;font-weight:700;padding:0.9rem 2.25rem;border-radius:10px;font-size:1rem;box-shadow:0 4px 14px rgba(255,107,53,0.35);transition:background 0.2s;text-decoration:none;" onmouseover="this.style.background='#e85a25'" onmouseout="this.style.background='#ff6b35'">Shop on Etsy</a>
  </section>

  <!-- Carousel -->
  <section style="max-width:820px;margin:0 auto;padding:0 2rem 4rem;">
    <div class="carousel-track">
      <div class="carousel-slide"><img src="/images/baby-album/mock1.png" alt="Personalized baby photo album" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/mock2.jpg" alt="Personalized baby photo album" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/mock3.jpg" alt="Personalized baby photo album" loading="lazy" /></div>
      <div class="carousel-slide"><img src="/images/baby-album/mock4.png" alt="Personalized baby photo album" loading="lazy" /></div>
    </div>
  </section>

  <!-- Peek Inside -->
  <section style="background:#f0eaff;padding:4rem 2rem;">
    <div style="max-width:960px;margin:0 auto;">
      <h2 style="text-align:center;font-size:1.75rem;font-weight:800;color:#2d1b69;margin-bottom:0.75rem;">Peek Inside</h2>
      <p style="text-align:center;color:#6b6b8a;margin-bottom:2rem;">Every page tells a story — yours.</p>
      <div class="peek-grid">
        <img src="/images/baby-album/page-01.png" alt="Album interior page 1" loading="lazy" />
        <img src="/images/baby-album/page-02.png" alt="Album interior page 2" loading="lazy" />
        <img src="/images/baby-album/page-03.png" alt="Album interior page 3" loading="lazy" />
        <img src="/images/baby-album/page-04.png" alt="Album interior page 4" loading="lazy" />
        <img src="/images/baby-album/page-05.png" alt="Album interior page 5" loading="lazy" />
        <img src="/images/baby-album/page-06.png" alt="Album interior page 6" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="text-align:center;padding:4rem 2rem;">
    <h2 style="font-size:1.5rem;font-weight:800;color:#2d1b69;margin-bottom:1rem;">Ready to preserve every milestone?</h2>
    <a href="https://www.etsy.com/shop/PersonalizedYouFinds" target="_blank" rel="noopener noreferrer" style="display:inline-block;background:#ff6b35;color:#ffffff;font-weight:700;padding:0.9rem 2.25rem;border-radius:10px;font-size:1rem;box-shadow:0 4px 14px rgba(255,107,53,0.35);transition:background 0.2s;text-decoration:none;" onmouseover="this.style.background='#e85a25'" onmouseout="this.style.background='#ff6b35'">Shop on Etsy</a>
  </section>

  <style>
    .carousel-track {
      display: flex;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      border-radius: 16px;
    }
    .carousel-track::-webkit-scrollbar { display: none; }
    .carousel-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }
    .carousel-slide img {
      width: 100%;
      height: auto;
      border-radius: 16px;
      display: block;
    }
    .peek-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .peek-grid img {
      width: 100%;
      height: auto;
      border-radius: 10px;
      display: block;
      box-shadow: 0 2px 8px rgba(45,27,105,0.1);
    }
    @media (max-width: 768px) {
      .peek-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

</Layout>
