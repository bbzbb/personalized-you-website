---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Personalized Keepsakes for Babies and Toddlers" description="Handcrafted personalized keepsakes for babies and toddlers ages 0 to 6. Custom baby photo albums and bedtime stories made just for your family.">

  <!-- Hero -->
  <section class="hero">
    <h1>The first years shape everything.<br><span> Capture those moments forever.</span></h1>
    <p>Personalized keepsakes for babies and toddlers ages 0 to 6 — handcrafted with love, built to last.</p>
  </section>

  <!-- Product Cards -->
  <section class="products">
    <div class="card">
      <div class="badge">Baby Album</div>
      <h2>Personalized Baby Photo Album</h2>
      <p>Preserve every milestone from the first year in a beautiful hardcover keepsake album, personalized with your baby's name.</p>
      <a href="/baby-album" class="btn-primary">See the Album →</a>
    </div>
    <div class="card">
      <div style="display:inline-block;background:#6B4A8A;color:#ffffff;font-weight:700;padding:0.9rem 2.5rem;border-radius:2rem;font-size:1.1rem;box-shadow:0 4px 14px rgba(107,74,138,0.3);transition:background 0.2s;" onmouseover="this.style.background='#4e3468'" onmouseout="this.style.background='#6B4A8A'">Bedtime Story</div>
      <h2>Custom Bedtime Story Book</h2>
      <p>A magical storybook starring your child by name — the perfect bedtime ritual and a gift they'll ask for every night.</p>
      <a href="/bedtime-stories" class="btn-secondary">See the Story →</a>
    </div>
  </section>

  <!-- Socials -->
  <section class="socials">
    <p class="socials-label">Follow along</p>
    <div class="socials-row">
      <!-- YouTube -->
      <a href="https://www.youtube.com/@PersonalizedYou" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5C4B43" width="32" height="32"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <!-- Instagram -->
      <a href="https://www.instagram.com/personalized.you" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5C4B43" width="32" height="32"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <!-- Pinterest -->
      <a href="https://www.pinterest.com/PersonalizedYou/" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5C4B43" width="32" height="32"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
      </a>
      <!-- X / Twitter -->
      <a href="https://x.com/PersonalizedYou" target="_blank" rel="noopener noreferrer" aria-label="X" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5C4B43" width="32" height="32"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
      </a>
      <!-- TikTok -->
      <a href="https://www.tiktok.com/@personalizedyou" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5C4B43" width="32" height="32"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
      </a>
    </div>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 5rem 2rem 3.5rem;
      max-width: 820px;
      margin: 0 auto;
      background: var(--cream);
      border-radius: 0 0 24px 24px;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      color: var(--latte);
    }
    .hero h1 span { color: #5C7A58; }
    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto;
    }
    .products {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      max-width: 960px;
      margin: 4rem auto;
      padding: 0 2rem;
    }
    .card {
      background: var(--beige);
      border: 1px solid var(--border);
      border-top: 3px solid #5C7A58;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .badge {
      display: inline-block;
      background: #A85C5C;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      width: fit-content;
    }
    .badge-lilac {
      background: #9A7DB8;
      color: #fff;
    }
    .card h2 {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--latte);
    }
    .card p {
      color: var(--muted);
      line-height: 1.6;
      flex: 1;
    }
    .btn-primary {
      display: inline-block;
      background: #A85C5C;
      color: #fff;
      font-weight: 700;
      padding: 0.8rem 1.75rem;
      border-radius: 2rem;
      font-size: 1rem;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
      width: fit-content;
    }
    .btn-primary:hover { background: #8f4a4a; text-decoration: none; }
    .btn-secondary {
      display: inline-block;
      background: #9A7DB8;
      color: #fff;
      font-weight: 700;
      padding: 0.8rem 1.75rem;
      border-radius: 2rem;
      font-size: 1rem;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
      width: fit-content;
    }
    .btn-secondary:hover { background: #4e3468; text-decoration: none; }
    .socials {
      text-align: center;
      padding: 1.5rem 2rem 0.5rem;
    }
    .socials-label {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
    }
    .socials-row {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      background: var(--beige);
      border-radius: 50%;
      border: 1px solid var(--border);
      transition: background 0.2s, transform 0.2s;
    }
    .social-link:hover {
      background: #5C4B43;
      transform: translateY(-2px);
      text-decoration: none;
    }
    .social-link:hover svg { fill: #fff; }
    @media (max-width: 640px) {
      .products { grid-template-columns: 1fr; }
    }
  </style>

</Layout>
