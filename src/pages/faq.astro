---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'What exactly is a personalized digital product?',
    a: "It's a digital file (PDF story or MP3 audio) handcrafted specifically for you, based on the personal details you provide. No two products are the same."
  },
  {
    q: 'How personalized is it really?',
    a: "Very. For bedtime stories, your child's name, age, and interests become part of the story. For meditation, your specific goals and intentions shape every word of the script."
  },
  {
    q: 'How quickly will I receive my order?',
    a: 'Most orders are delivered within 24 hours. During busy periods it may take up to 48 hours. You\'ll receive your file via email.'
  },
  {
    q: 'What is your refund policy?',
    a: 'Because these are custom digital products created specifically for you, we do not offer refunds once the file is delivered. If you\'re unhappy with quality, contact us and we\'ll make it right.'
  },
  {
    q: 'What format will I receive?',
    a: 'Bedtime stories are delivered as a PDF. Guided meditations are delivered as an MP3 audio file. Both work on any device.'
  },
  {
    q: 'Can I request revisions?',
    a: "Yes! We offer one free revision per order. Just reply to your delivery email with what you'd like changed and we'll update it for you."
  },
  {
    q: 'Are the bedtime stories safe and appropriate for children?',
    a: "Absolutely. All stories are reviewed for age-appropriate content before delivery. We take children's safety seriously and ensure every story is positive, encouraging, and wholesome."
  },
  {
    q: 'How do you handle my personal information?',
    a: 'We use the information you provide only to create your product. We do not sell or share your data with third parties. See our Privacy Policy for full details.'
  },
];
---
<Layout title="FAQ" description="Frequently asked questions about Personalized You products.">
  <div style="max-width:700px;margin:0 auto;padding:4rem 2rem;">
    <h1 style="font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;text-align:center;color:#b07d50;">Frequently Asked Questions</h1>
    <p style="color:#7a6a5a;text-align:center;margin-bottom:3rem;">Everything you need to know before ordering.</p>

    <div style="display:flex;flex-direction:column;gap:1rem;">
      {faqs.map((faq, i) => (
        <details style="background:#e8d9c5;border:1px solid #d9cfc4;border-radius:12px;padding:1.25rem 1.5rem;cursor:pointer;">
          <summary style="font-weight:600;font-size:1rem;list-style:none;display:flex;justify-content:space-between;align-items:center;color:#3a2e28;">
            {faq.q}
            <span style="color:#7a9e7e;font-size:1.25rem;flex-shrink:0;margin-left:1rem;">+</span>
          </summary>
          <p style="color:#7a6a5a;margin-top:1rem;line-height:1.7;">{faq.a}</p>
        </details>
      ))}
    </div>

    <p style="text-align:center;margin-top:3rem;color:#7a6a5a;">
      Still have questions? <a href="/contact">Contact us</a> — we're happy to help.
    </p>
  </div>
</Layout>
