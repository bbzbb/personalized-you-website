---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'What does Personalized You sell?',
    a: 'We make two products: personalized hardcover baby photo albums and custom bedtime story books for children ages 0 to 6. Everything is made specifically for your child — their name, their details, their story.'
  },
  {
    q: 'What is the personalized baby photo album?',
    a: 'It is a professionally printed hardcover photo book with your baby name and birth date on the cover. Inside are 24 custom-designed pages covering monthly milestones, first moments, and a letter page — all laid out for you. You choose the size, finish, and cover color at checkout. It ships from our US-based print partner in 3 to 5 business days.'
  },
  {
    q: 'What is the custom bedtime story?',
    a: 'It is an original story written around your child — their name, age, personality, and favorite things become part of the adventure. We deliver it as a read-aloud audio file within 24 hours. Perfect for children ages 0 to 6.'
  },
  {
    q: 'How personalized are these products really?',
    a: 'Completely. The baby album has your baby name and birth date printed on the cover with a color you choose. The bedtime story is written from scratch around your child — not a template, not a fill-in-the-blank. Every product is made just for your family.'
  },
  {
    q: 'Where are orders shipped from?',
    a: 'Baby photo albums are printed and shipped by our US-based print partner. Handling time is 3 to 5 business days plus transit. Bedtime stories are delivered digitally by email within 24 hours — no shipping required.'
  },
  {
    q: 'Do you ship internationally?',
    a: 'Baby photo albums currently ship within the US only. Bedtime stories are delivered digitally and available worldwide.'
  },
  {
    q: 'What sizes and finishes are available for the baby album?',
    a: 'Two sizes: 8x8 inch (cozy and shelf-friendly, $42) and 11x8.5 inch (landscape format with more room for photos, $58). Both come in matte or glossy finish. Matte is our personal favorite — soft, rich, no glare.'
  },
  {
    q: 'What cover colors are available?',
    a: 'Sage green and rose gold. Just leave your color preference in the personalization note at checkout.'
  },
  {
    q: 'What if I made a mistake in my personalization details?',
    a: 'Message us as soon as possible after ordering. If your album has not gone to print yet, we can fix it. Once printed we cannot make changes, so please double-check your note at checkout.'
  },
  {
    q: 'What is your refund policy?',
    a: 'Baby albums are custom-printed for your order so we cannot accept returns. If something arrives damaged or incorrect, message us with a photo and we will make it right. For bedtime stories, if your child does not love it, we offer a full refund — no questions asked. That is our Bedtime Promise.'
  },
  {
    q: 'Can I request a revision on my bedtime story?',
    a: 'Yes. We offer one free revision per order. Just reply to your delivery email with what you would like changed and we will update it for you.'
  },
  {
    q: 'Are the stories safe and age-appropriate?',
    a: 'Absolutely. Every story is reviewed before delivery. All content is positive, encouraging, and wholesome — designed for children ages 0 to 6.'
  },
  {
    q: 'How do you handle my personal information?',
    a: 'We use the details you provide only to create your product. We do not sell or share your data with third parties. See our Privacy Policy for full details.'
  },
  {
    q: 'Is this a good baby shower or birthday gift?',
    a: 'It is one of the most thoughtful ones out there. For the baby album, just leave the baby name and birth date in the notes — or message us and we will help you sort out the details. For bedtime stories, the child name and a few details about them is all we need.'
  },
];
---
<Layout title="FAQ | Personalized You" description="Frequently asked questions about our personalized baby photo albums and custom bedtime stories for children ages 0 to 6.">
  <div style="max-width:700px;margin:0 auto;padding:4rem 2rem;">
    <h1 style="font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;text-align:center;color:var(--latte);">Frequently Asked Questions</h1>
    <p style="color:var(--muted);text-align:center;margin-bottom:3rem;">Everything you need to know before ordering.</p>

    <div style="display:flex;flex-direction:column;gap:1rem;">
      {faqs.map((faq, i) => (
        <details style="background:var(--beige);border:1px solid var(--border);border-radius:12px;padding:1.25rem 1.5rem;cursor:pointer;">
          <summary style="font-weight:600;font-size:1rem;list-style:none;display:flex;justify-content:space-between;align-items:center;color:var(--text);">
            {faq.q}
            <span style="color:var(--sage);font-size:1.25rem;flex-shrink:0;margin-left:1rem;">+</span>
          </summary>
          <p style="color:var(--muted);margin-top:1rem;line-height:1.7;">{faq.a}</p>
        </details>
      ))}
    </div>

    <p style="text-align:center;margin-top:3rem;color:var(--muted);">
      Still have questions? <a href="/contact">Contact us</a> — we're happy to help.
    </p>
  </div>
</Layout>
