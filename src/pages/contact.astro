---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us" description="Get in touch with Personalized You — we'd love to hear from you.">
  <div style="max-width:600px;margin:0 auto;padding:4rem 2rem;">
    <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:0.75rem;text-align:center;">Contact Us</h1>
    <p style="color:#a8b8d0;text-align:center;margin-bottom:2.5rem;">Have a question or special request? We'd love to hear from you.</p>

    <form action="mailto:01jdof8eq9@gmail.com" method="post" enctype="text/plain"
      style="background:#0d1f3c;border:1px solid #1e3a5f;border-radius:16px;padding:2rem;display:flex;flex-direction:column;gap:1.25rem;">
      <div>
        <label style="display:block;color:#a8b8d0;font-size:0.875rem;margin-bottom:0.4rem;" for="name">Your Name</label>
        <input id="name" name="name" type="text" required
          style="width:100%;background:#0a1628;border:1px solid #1e3a5f;border-radius:8px;padding:0.75rem 1rem;color:#fff;font-size:1rem;outline:none;"
          onfocus="this.style.borderColor='#ffd700'" onblur="this.style.borderColor='#1e3a5f'" />
      </div>
      <div>
        <label style="display:block;color:#a8b8d0;font-size:0.875rem;margin-bottom:0.4rem;" for="email">Your Email</label>
        <input id="email" name="email" type="email" required
          style="width:100%;background:#0a1628;border:1px solid #1e3a5f;border-radius:8px;padding:0.75rem 1rem;color:#fff;font-size:1rem;outline:none;"
          onfocus="this.style.borderColor='#ffd700'" onblur="this.style.borderColor='#1e3a5f'" />
      </div>
      <div>
        <label style="display:block;color:#a8b8d0;font-size:0.875rem;margin-bottom:0.4rem;" for="message">Message</label>
        <textarea id="message" name="message" rows="5" required
          style="width:100%;background:#0a1628;border:1px solid #1e3a5f;border-radius:8px;padding:0.75rem 1rem;color:#fff;font-size:1rem;outline:none;resize:vertical;"
          onfocus="this.style.borderColor='#ffd700'" onblur="this.style.borderColor='#1e3a5f'"></textarea>
      </div>
      <button type="submit"
        style="background:#ffd700;color:#0a1628;font-weight:700;padding:0.875rem;border-radius:8px;border:none;font-size:1rem;cursor:pointer;">
        Send Message
      </button>
    </form>
  </div>
</Layout>
