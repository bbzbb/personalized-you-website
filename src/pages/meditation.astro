---
import Layout from '../layouts/Layout.astro';

const plans = [
  { duration: '5 Minutes', price: '$9.99', desc: 'Perfect for a quick reset or daily practice.' },
  { duration: '10 Minutes', price: '$19', desc: 'A deeper session to reduce stress and find clarity.' },
  { duration: '15 Minutes', price: '$24', desc: 'Full immersive experience for profound relaxation.', featured: true },
];
---
<Layout title="Personalized Guided Meditation" description="Custom guided meditation audio tailored to your goals and intentions. Starting at $9.99.">
  <div style="max-width:800px;margin:0 auto;padding:4rem 2rem;">

    <!-- Hero -->
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:3rem;margin-bottom:1rem;">🧘</div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.75rem);font-weight:800;line-height:1.2;margin-bottom:1rem;color:#1a1a2e;">
        Sounds like it was made just for you.<br><span style="color:#7c5cbf">That's because it was.</span>
      </h1>
      <p style="font-size:1.15rem;color:#6b6b8a;max-width:540px;margin:0 auto 2rem;">
        A custom audio meditation built around your specific goals, challenges, and the quiet you've been missing.
      </p>
      <a href="https://guidedmeditation.lemonsqueezy.com" target="_blank" rel="noopener noreferrer"
        style="display:inline-block;background:#ff6b35;color:#ffffff;font-weight:700;padding:0.9rem 2.5rem;border-radius:10px;font-size:1.1rem;box-shadow:0 4px 14px rgba(255,107,53,0.35);transition:background 0.2s;"
        onmouseover="this.style.background='#e85a25'" onmouseout="this.style.background='#ff6b35'">
        Get It Now — From $9.99
      </a>
      <p style="color:#6b6b8a;margin-top:0.75rem;font-size:0.875rem;">Secure checkout · Delivered in 24 hours</p>
    </div>

    <!-- How It Works -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#2d1b69;font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;text-align:center;">How It Works</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
        {[
          { n: '1', icon: '💬', title: "Share what's weighing on you", body: "Tell us what you're carrying — stress, sleeplessness, anxiety, or something harder to name." },
          { n: '2', icon: '🎙️', title: 'We create your session', body: 'A script is written around your words and recorded with a calming voice just for you.' },
          { n: '3', icon: '🌿', title: "You find the quiet you've been missing", body: 'Receive your MP3 within 24 hours. Press play whenever you need it.' },
        ].map(s => (
          <div style="background:#ffffff;border:2px solid #e8dff5;border-radius:14px;padding:1.5rem;text-align:center;box-shadow:0 2px 8px rgba(45,27,105,0.06);">
            <div style="font-size:2rem;margin-bottom:0.5rem;">{s.icon}</div>
            <div style="color:#7c5cbf;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;margin-bottom:0.5rem;">STEP {s.n}</div>
            <h3 style="font-size:1rem;font-weight:700;color:#1a1a2e;margin-bottom:0.5rem;">{s.title}</h3>
            <p style="color:#6b6b8a;font-size:0.9rem;line-height:1.6;">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing tiers -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#2d1b69;font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;text-align:center;">Choose Your Length</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
        {plans.map(p => (
          <div style={`background:#ffffff;border:2px solid ${p.featured ? '#7c5cbf' : '#e8dff5'};border-radius:16px;padding:1.75rem;text-align:center;box-shadow:0 2px 8px rgba(45,27,105,0.06);${p.featured ? 'position:relative;' : ''}`}>
            {p.featured && <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#7c5cbf;color:#ffffff;font-size:0.75rem;font-weight:700;padding:3px 14px;border-radius:99px;">MOST POPULAR</div>}
            <h3 style="font-size:1.2rem;font-weight:700;color:#1a1a2e;margin-bottom:0.5rem;">{p.duration}</h3>
            <p style="font-size:2rem;font-weight:800;color:#ff6b35;margin-bottom:0.5rem;">{p.price}</p>
            <p style="color:#6b6b8a;font-size:0.9rem;">{p.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Guarantee -->
    <section style="background:#fff7f4;border:2px solid #ff6b35;border-radius:20px;padding:2rem;text-align:center;margin-bottom:3rem;">
      <p style="color:#ff6b35;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;margin-bottom:0.75rem;">OUR GUARANTEE</p>
      <h2 style="font-size:1.4rem;font-weight:800;color:#1a1a2e;margin-bottom:0.75rem;">The Peace Guarantee</h2>
      <p style="color:#6b6b8a;line-height:1.7;max-width:500px;margin:0 auto;">
        If you don't feel calmer after your first listen, full refund. No questions, no hassle — just reach out.
      </p>
    </section>

    <!-- Testimonials -->
    <section style="margin-bottom:3rem;">
      <h2 style="color:#2d1b69;font-size:1.5rem;font-weight:800;margin-bottom:1.5rem;text-align:center;">What people are saying</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;">
        {[
          { name: 'Lauren B.', location: 'Denver, CO', quote: "I've tried every meditation app. This is the first time it actually felt like someone understood what I was going through. I listen every morning now." },
          { name: 'Marcus R.', location: 'Atlanta, GA', quote: "I ordered the 10-minute session after a brutal week at work. Fell asleep before it finished. Best $19 I've ever spent." },
          { name: 'Nadia S.', location: 'Seattle, WA', quote: "The voice even mentioned the specific things I was stressed about. It felt eerily personal — in the best possible way." },
        ].map(t => (
          <div style="background:#ffffff;border:2px solid #e8dff5;border-radius:14px;padding:1.5rem;box-shadow:0 2px 8px rgba(45,27,105,0.06);">
            <div style="color:#ffb347;font-size:1rem;margin-bottom:0.75rem;">★★★★★</div>
            <p style="color:#1a1a2e;line-height:1.7;font-size:0.95rem;margin-bottom:1rem;">"{t.quote}"</p>
            <p style="color:#2d1b69;font-weight:700;font-size:0.875rem;">{t.name}</p>
            <p style="color:#6b6b8a;font-size:0.8rem;">{t.location}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div style="text-align:center;">
      <a href="https://guidedmeditation.lemonsqueezy.com" target="_blank" rel="noopener noreferrer"
        style="display:inline-block;background:#ff6b35;color:#ffffff;font-weight:700;padding:1rem 2.75rem;border-radius:10px;font-size:1.1rem;box-shadow:0 4px 14px rgba(255,107,53,0.35);transition:background 0.2s;"
        onmouseover="this.style.background='#e85a25'" onmouseout="this.style.background='#ff6b35'">
        Get It Now
      </a>
      <p style="color:#6b6b8a;margin-top:1rem;font-size:0.875rem;">Secure checkout via LemonSqueezy</p>
    </div>
  </div>
</Layout>
