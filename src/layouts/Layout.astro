---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object;
}
const {
  title,
  description = 'Personalized handcrafted digital products made just for you.',
  canonical,
  ogImage = 'https://www.personalized-you.com/og-default.jpg',
  ogType = 'website',
  schema,
} = Astro.props;
const canonicalUrl = canonical ?? `https://www.personalized-you.com${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Personalized You</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Personalized You`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Personalized You" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Personalized You`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #f5f0eb;
        --surface: #eeebe6;
        --surface-alt: #eeebe6;
        --border: #d9d3cc;
        --primary: #8aab8e;
        --primary-light: #8aab8e;
        --accent: #8aab8e;
        --accent-hover: #6d8e71;
        --text: #2c2c2c;
        --muted: #7a7068;
        --star: #8aab8e;
        --story-bg: #eeebe6;
      }
      body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }
      a { color: var(--primary); text-decoration: none; }
      a:hover { text-decoration: underline; }
      nav { background: var(--surface); padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 64px; box-shadow: 0 2px 8px rgba(44,44,44,0.08); }
      .nav-logo { font-size: 1.25rem; font-weight: 800; color: #2c2c2c; letter-spacing: -0.01em; }
      .nav-logo span { color: var(--primary); }
      .nav-links { display: flex; gap: 1.5rem; list-style: none; }
      .nav-links a { color: #2c2c2c; font-size: 0.95rem; transition: color 0.2s; }
      .nav-links a:hover { color: var(--primary); text-decoration: none; }
      .hamburger { display: none; background: none; border: none; cursor: pointer; color: #2c2c2c; font-size: 1.5rem; }
      main { flex: 1; }
      footer { background: var(--surface); text-align: center; padding: 1.75rem; color: var(--muted); font-size: 0.875rem; }
      footer a { color: var(--text); }
      footer a:hover { color: var(--primary); }
      @media (max-width: 768px) {
        .hamburger { display: block; }
        .nav-links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--surface); flex-direction: column; padding: 1rem 2rem; gap: 1rem; border-top: 1px solid rgba(44,44,44,0.1); z-index: 100; }
        .nav-links.open { display: flex; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a class="nav-logo" href="/">Personalized You</a>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">☰</button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/bedtime-stories">Stories</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 Personalized You &nbsp;·&nbsp; <a href="/policies">Privacy & Terms</a> &nbsp;·&nbsp; <a href="/faq">FAQ</a></p>
    </footer>
    <script>
      const btn = document.getElementById('hamburger');
      const links = document.getElementById('nav-links');
      btn?.addEventListener('click', () => links?.classList.toggle('open'));
    </script>
  </body>
</html>
